# ============================================================
#  Environment Variables — TSAK Web
#  คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริง (ห้าม commit .env.local)
# ============================================================

# Service Account ของอีเมลกลางชมรม
# 1) เปิด https://console.cloud.google.com → สร้าง Project ใหม่ (ฟรี)
# 2) เปิดใช้งาน "Google Sheets API"
# 3) สร้าง Service Account → Generate JSON key → คัดลอกค่าจาก JSON มาวาง
GOOGLE_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"

# ค่า private_key จาก JSON — ต้องคงเครื่องหมาย \n ไว้แบบนี้ (Vercel เก็บแบบ string)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Sheet ID ของ Google Sheet ที่เป็นฐานข้อมูล (ดูจาก URL ของ Sheet)
# https://docs.google.com/spreadsheets/d/<<<THIS_ID>>>/edit
GOOGLE_SHEET_ID="1AbCdEfGhIjKlMnOpQrStUvWxYz0123456789"

# (ตัวเลือก) ตั้ง revalidate cache ของ ISR เป็นวินาที — default 60 วินาที
NEXT_PUBLIC_SHEETS_REVALIDATE_SECONDS="60"

# ─────────────────────────────────────────────────
# Coming Soon mode (สำหรับช่วงพัฒนา / ก่อน launch)
# ─────────────────────────────────────────────────
# ตั้ง "coming_soon" → ผู้เข้าชมเห็น splash page เท่านั้น
# ลบ env var ออก หรือเปลี่ยนเป็น "live" → เว็บจริงเปิดให้ทุกคน
# NEXT_PUBLIC_SITE_STATUS="coming_soon"

# Preview bypass key — สำหรับให้ committee/ผู้พัฒนาดูเว็บจริงตอน coming soon mode
# ใช้: ใส่ ?preview=YOUR_KEY ท้าย URL ครั้งเดียว → จำ cookie 30 วัน
# PREVIEW_KEY="ตั้งคำสุ่มยาวๆ-เช่น-tsak-secret-2026"
